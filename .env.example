# API base URL (Django backend)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Google OAuth — replace YOUR_CLIENT_ID with your Google Cloud client ID
VITE_GOOGLE_LINK=https://accounts.google.com/o/oauth2/v2/auth?client_id=YOUR_CLIENT_ID&redirect_uri=http://localhost:3000&response_type=token&scope=openid%20email%20profile&prompt=consent

# Auth endpoints (derived from API base — kept for backward compatibility)
VITE_GOOGLELOGIN=http://127.0.0.1:8000/google/login/
VITE_USERME=http://127.0.0.1:8000/users/me/
VITE_BLACKLIST=http://127.0.0.1:8000/token/blacklist/
VITE_REFRESHTOKEN=http://127.0.0.1:8000/token/refresh/
